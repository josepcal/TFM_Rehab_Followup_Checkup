APP_ENV=dev
AUTH_MODE=dev                 # dev | keycloak   (dev PROHIBIDO en prod)
DATABASE_URL=postgresql://ftm_app:thisIsMyFTMAppDBPassword123@localhost:5432/appdb
KEYCLOAK_ISSUER=http://localhost:8080/realms/ftm
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/ftm/protocol/openid-connect/certs
WAV_BUCKET=                   # vacío => almacenamiento local (dev)
WAV_LOCAL_DIR=/tmp/ftm-recordings
STORAGE_BACKEND=local         # local | s3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=eu-west-1
S3_FORCE_PATH_STYLE=false
LLM_API_KEY=
LLM_MODEL=claude-3-5-sonnet-latest
NATIONAL_ID_ENCRYPTION_KEY=