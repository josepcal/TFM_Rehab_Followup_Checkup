# Credenciales de la BD de la app (servicio postgres-app).
# Copia este fichero a .env.  Los valores DEBEN coincidir con la conexion
# que tienes en alembic.ini (sqlalchemy.url), para que la BD se cree con las
# mismas credenciales con las que Alembic intenta conectar.

POSTGRES_USER=appuser
POSTGRES_PASSWORD=thisIsMyAppDBPassword123
POSTGRES_DB=appdb

# Usuario runtime de la API (no owner). Lo crea la migración 0003.
FTM_APP_DB_PASSWORD=thisIsMyFTMAppDBPassword123
